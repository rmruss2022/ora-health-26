# Backend API Configuration
# This is the URL of your backend API (NOT AWS credentials)
# The mobile app only talks to your backend, never directly to AWS
API_BASE_URL=https://api.shadow-ai.com
# For local development:
# API_BASE_URL=http://localhost:3000

# App Configuration
APP_ENV=development

# ElevenLabs Voice
# Optional: leave blank to use backend default agent id.
EXPO_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
EXPO_PUBLIC_ELEVENLABS_AGENT_ID=your_private_ora_agent_id_here

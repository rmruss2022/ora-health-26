# Server Configuration
PORT=3000
NODE_ENV=development

# AI Provider Configuration (NVIDIA only)
AI_PROVIDER=nvidia

# NVIDIA Kimi K2.5 Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.5
NVIDIA_MAX_TOKENS=2000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:19006,exp://192.168.1.100:8081

# OpenAI Configuration (for vector embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs Voice Agent (private-agent token minting)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_ORA_AGENT_ID=your_private_ora_agent_id_here
